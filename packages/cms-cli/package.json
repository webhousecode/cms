{
  "name": "@webhouse/cms-cli",
  "version": "0.1.0",
  "description": "CLI for @webhouse/cms",
  "type": "module",
  "bin": {
    "cms": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@webhouse/cms": "workspace:*",
    "@webhouse/cms-ai": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "jiti": "^2.4.2",
    "citty": "^0.1.6",
    "chokidar": "^4.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsup": "^8.3.5"
  }
}
