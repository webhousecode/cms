{
  "name": "@broberg/cms-chat-client",
  "version": "0.4.17",
  "description": "Copy-owned browser client for the @webhouse/cms chat — quick-action cache (peek/warm). Grows into the full chat client, paired with @broberg/cms-chat-server.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webhousecode/cms.git",
    "directory": "packages/cms-chat-client"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
