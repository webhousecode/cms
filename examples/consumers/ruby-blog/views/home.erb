<% @title = "Blog (#{@locale})" %>
<h1>Blog</h1>
<p class="lead">Content read from @webhouse/cms JSON files by a Sinatra / Ruby <%= @locale %> app.</p>

<% if @posts.empty? %>
    <p>No published posts yet.</p>
<% end %>

<% @posts.each do |post| %>
    <a href="/blog/<%= post['slug'] %>" class="post-card">
        <div class="meta">
            <span><%= post.dig('data', 'date') %></span>
            <span> · </span>
            <span><%= post['locale'] %></span>
        </div>
        <h3><%= wh_string(post, 'title') %></h3>
        <p><%= wh_string(post, 'excerpt') %></p>
    </a>
<% end %>
